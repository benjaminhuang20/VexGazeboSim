<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="testRobot1">
    <static>false</static>

    <link name="chassis">
      <pose>0 0 0.25 0 0 0</pose>
      <inertial>
        <mass>4.53592</mass>
        <inertia>
          <ixx>0.1597</ixx>
          <iyy>0.4016</iyy>
          <izz>0.5142</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <box>
            <size>1.0 0.6 0.25</size>
          </box>
        </geometry>
      </collision>

      <visual name="visual">
        <geometry>
          <box>
            <size>1.0 0.6 0.25</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.8 1</ambient>
          <diffuse>0.1 0.1 0.8 1</diffuse>
        </material>
      </visual>

      <sensor name="imu_sensor" type="imu">
        <topic>/imuTest</topic>
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <visualize>true</visualize>
      </sensor>
    </link>

    <link name="left_wheel">
      <pose relative_to="chassis">0.4 0.4 -0.1 1.5708 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.00323</ixx>
          <iyy>0.00323</iyy>
          <izz>0.00563</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.1</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>2.0</mu>
              <mu2>0.1</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.1</length>
          </cylinder>
        </geometry>
      </visual>
    </link>

    <link name="right_wheel">
      <pose relative_to="chassis">0.4 -0.4 -0.1 1.5708 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.00323</ixx>
          <iyy>0.00323</iyy>
          <izz>0.00563</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.1</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>2.0</mu>
              <mu2>0.1</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.1</length>
          </cylinder>
        </geometry>
      </visual>
    </link>

    <link name="rear_left_wheel">
      <pose relative_to="chassis">-0.4 0.4 -0.1 1.5708 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.00323</ixx>
          <iyy>0.00323</iyy>
          <izz>0.00563</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.1</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>2.0</mu>
              <mu2>0.1</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.1</length>
          </cylinder>
        </geometry>
      </visual>
    </link>

    <link name="rear_right_wheel">
      <pose relative_to="chassis">-0.4 -0.4 -0.1 1.5708 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.00323</ixx>
          <iyy>0.00323</iyy>
          <izz>0.00563</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.1</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>2.0</mu>
              <mu2>0.1</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.1</length>
          </cylinder>
        </geometry>
      </visual>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <pose relative_to="chassis">0.4 0.4 -0.1 0 0 0</pose>
      <parent>chassis</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <dynamics>
          <damping>0.05</damping>
          <friction>0.01</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <pose relative_to="chassis">0.4 -0.4 -0.1 0 0 0</pose>
      <parent>chassis</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <dynamics>
          <damping>0.05</damping>
          <friction>0.01</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="back_left_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>rear_left_wheel</child>
      <axis>
        <xyz>0 0 -1</xyz>
        <dynamics>
          <damping>0.05</damping>
          <friction>0.01</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="back_right_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>rear_right_wheel</child>
      <axis>
        <xyz>0 0 -1</xyz>
        <dynamics>
          <damping>0.05</damping>
          <friction>0.01</friction>
        </dynamics>
      </axis>
    </joint>

    <plugin filename="libTankDrivePlugin"
            name="TankDrivePlugin">
      <topic>/tank_cmd</topic>
      <rpm>600</rpm>
    </plugin>
  </model>
</sdf>
